PORT=3000
NODE_ENV=production

BOT_TOKEN=
WEB_APP_URL=
PUBLIC_BASE_URL=
WEBHOOK_SECRET=

SESSION_JWT_SECRET=

# Remnawave: только полный URL API: https://host или http://host:port (без слэша в конце).
# Сюда не клади JWT — токен ниже. Перепутанные поля дают ошибку «Failed to parse URL from eyJ...».
# Не подставляй домен «панели», если он не проксирует /api наружу.
REMNAWAVE_BASE_URL=
REMNAWAVE_ACCESS_TOKEN=
REMNAWAVE_USERNAME=
REMNAWAVE_PASSWORD=

# Если nginx на `REMNAWAVE_BASE_URL` маскирует доступ к `/api/*` и пускает
# только при наличии cookie — укажи её тут целиком.
# У тебя в nginx.conf: XkhRCZEJ=nEnUoUYP
REMNAWAVE_BYPASS_COOKIE=

REMNAWAVE_INTERNAL_SQUAD_UUIDS=
REMNAWAVE_DEFAULT_TRAFFIC_LIMIT_BYTES=0
REMNAWAVE_DEFAULT_HWID_DEVICE_LIMIT=2

PAYMENT_WEBHOOK_SECRET=
# CORS_ORIGIN=https://...

# Тестовый режим: выдавать/продлевать подписку без проверки оплаты
# 1 = включено, 0/пусто = выключено
TEST_GRANT_ENABLED=0