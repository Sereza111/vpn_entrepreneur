PORT=3000
NODE_ENV=production

BOT_TOKEN=
WEB_APP_URL=
PUBLIC_BASE_URL=
WEBHOOK_SECRET=

SESSION_JWT_SECRET=

# Subscription source (fixed to XUI)
PRIMARY_SUBSCRIPTION_SOURCE=xui

# Optional: 3X-UI base URL. Needed only if you link by token (sub id) instead of full URL.
# Example: https://panel.example.com:2096
XUI_BASE_URL=
# Panel URL (login + /panel/api/*). Often same as XUI_BASE_URL.
XUI_PANEL_BASE_URL=
# Точный Web Base Path из панели (например /8dFlsHsLZMTgKsrUhd/). С регистром как в 3X-UI.
XUI_WEB_BASE_PATH=
XUI_USERNAME=
XUI_PASSWORD=
# Inbound ID where bot should create clients
XUI_INBOUND_ID=
# Subscription path root (default: /sub)
XUI_SUB_PATH=/sub
# If 3X-UI uses self-signed TLS cert, set to 1.
XUI_INSECURE_TLS=0

# Proxy servers list (JSON). Each user gets unique login/password via SSH.
# Example:
# PROXY_SERVERS_JSON=[{"id":"nl1","country":"NL","host":"72.56.86.167","socksPort":1080,"httpPort":3128,"ssh":{"host":"72.56.86.167","port":22,"user":"root","privateKeyB64":"BASE64_OF_PRIVATE_KEY"},"containerName":"3proxy","configPath":"/opt/3proxy/3proxy.cfg"}]
PROXY_SERVERS_JSON=[]

PAYMENT_WEBHOOK_SECRET=
# CORS_ORIGIN=https://...

# Тестовый режим: выдавать/продлевать подписку без проверки оплаты
# 1 = включено, 0/пусто = выключено
TEST_GRANT_ENABLED=0