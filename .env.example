PORT=3000
NODE_ENV=production

BOT_TOKEN=
WEB_APP_URL=
PUBLIC_BASE_URL=
WEBHOOK_SECRET=

SESSION_JWT_SECRET=

# Primary subscription source returned to users by default:
# - remnawave: use Remnawave user's subscriptionUrl (optionally merged with BYPASS_SUBSCRIPTION_URL)
# - xui: use 3X-UI subscription linked per Telegram user (via /api/link-xui)
PRIMARY_SUBSCRIPTION_SOURCE=remnawave

# Optional: 3X-UI base URL. Needed only if you link by token (sub id) instead of full URL.
# Example: https://panel.example.com:2096
XUI_BASE_URL=
# Panel URL (login + /panel/api/*). Often same as XUI_BASE_URL.
XUI_PANEL_BASE_URL=
XUI_USERNAME=
XUI_PASSWORD=
# Inbound ID where bot should create clients
XUI_INBOUND_ID=
# Subscription path root (default: /sub)
XUI_SUB_PATH=/sub
# If 3X-UI uses self-signed TLS cert, set to 1.
XUI_INSECURE_TLS=0

# Remnawave: только полный URL API: https://host или http://host:port (без слэша в конце).
# Сюда не клади JWT — токен ниже. Перепутанные поля дают ошибку «Failed to parse URL from eyJ...».
# Не подставляй домен «панели», если он не проксирует /api наружу.
REMNAWAVE_BASE_URL=
REMNAWAVE_ACCESS_TOKEN=
REMNAWAVE_USERNAME=
REMNAWAVE_PASSWORD=

# Если nginx на `REMNAWAVE_BASE_URL` маскирует доступ к `/api/*` и пускает
# только при наличии cookie — укажи её тут целиком.
# У тебя в nginx.conf: XkhRCZEJ=nEnUoUYP
REMNAWAVE_BYPASS_COOKIE=

REMNAWAVE_INTERNAL_SQUAD_UUIDS=
REMNAWAVE_DEFAULT_TRAFFIC_LIMIT_BYTES=0
REMNAWAVE_DEFAULT_HWID_DEVICE_LIMIT=2

# Optional: external subscription (e.g. 3X-UI bypass) to merge into Remnawave subscription.
# Put full URL to the 3X-UI subscription here (it can be base64 or plain text list).
BYPASS_SUBSCRIPTION_URL=
# If 3X-UI uses self-signed TLS cert, set to 1.
BYPASS_INSECURE_TLS=0

PAYMENT_WEBHOOK_SECRET=
# CORS_ORIGIN=https://...

# Тестовый режим: выдавать/продлевать подписку без проверки оплаты
# 1 = включено, 0/пусто = выключено
TEST_GRANT_ENABLED=0