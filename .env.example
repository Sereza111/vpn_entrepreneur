PORT=3000
NODE_ENV=production

BOT_TOKEN=
WEB_APP_URL=
PUBLIC_BASE_URL=
WEBHOOK_SECRET=

# Если в логах ETIMEDOUT на setWebhook — с хоста не достучаться до api.telegram.org (блокировка/фаервол).
# Мини‑приложение при этом может работать, если процесс не падает; см. устойчивый старт в src/index.js.
# TELEGRAM_SKIP_WEBHOOK_SETUP=1
# TELEGRAM_WEBHOOK_RETRIES=12
# TELEGRAM_WEBHOOK_RETRY_MS=5000
# TELEGRAM_WEBHOOK_RETRY_INTERVAL_MS=300000
# Node 20 fetch по умолчанию не читает HTTPS_PROXY; при необходимости поднимайте бота на VPS с доступом к Telegram API.

SESSION_JWT_SECRET=
# TTL для токена мини‑аппа (JWT), пример: 7d, 24h, 12h
# SESSION_JWT_EXPIRES_IN=7d

# Subscription source (fixed to XUI)
PRIMARY_SUBSCRIPTION_SOURCE=xui

# Optional: 3X-UI base URL. Needed only if you link by token (sub id) instead of full URL.
# Example: https://panel.example.com:2096
XUI_BASE_URL=
# Panel URL (login + /panel/api/*). Often same as XUI_BASE_URL.
XUI_PANEL_BASE_URL=
# Точный Web Base Path из панели (например /8dFlsHsLZMTgKsrUhd/). С регистром как в 3X-UI.
XUI_WEB_BASE_PATH=
XUI_USERNAME=
XUI_PASSWORD=
# Inbound ID where bot should create clients
XUI_INBOUND_ID=
# Subscription path root (default: /sub)
XUI_SUB_PATH=/sub
# Дополнительные сервера подписки (через запятую), если хотите одной ссылкой склеивать RU+NL
# Работает для token/subId; пример:
# XUI_EXTRA_BASE_URLS=https://158.160.245.62:2096,https://72.56.86.167:2096
# Если в /api/link-xui передать несколько полных URL, они тоже будут объединены.
# Можно объединять несколько подписок для одного пользователя:
# POST /api/link-xui с subscriptionUrlOrToken в формате
# "https://ru-panel/sub/<id>\nhttps://nl-panel/sub/<id>"
# If 3X-UI uses self-signed TLS cert, set to 1.
XUI_INSECURE_TLS=0
# Имя узла в VPN-клиенте (remark в 3X-UI). Плейсхолдеры: {subscriptionTitle} {telegramId} {username}
# XUI_CLIENT_REMARK_TEMPLATE={subscriptionTitle} · {username}
# Суффикс, который часть клиентов показывает после имени (в формате remark-email).
# Поставьте флаг, например: 🇷🇺
# XUI_CLIENT_DISPLAY_SUFFIX=🌐

# Автосоздание клиента на втором XUI (например NL) с тем же subId.
# Без XUI_SECONDARY_ENABLED=1 остальные XUI_SECONDARY_* игнорируются (клиент на NL не создаётся).
# XUI_SECONDARY_ENABLED=1
# XUI_SECONDARY_PANEL_BASE_URL=http://72.56.86.167:26033
# XUI_SECONDARY_WEB_BASE_PATH=/8dFlsHsLZMTgKsrUhd/
# XUI_SECONDARY_USERNAME=
# XUI_SECONDARY_PASSWORD=
# XUI_SECONDARY_INBOUND_ID=1
# XUI_SECONDARY_INSECURE_TLS=0
# XUI_SECONDARY_REMARK_PREFIX=🇳🇱 NL |

# Proxy servers list (JSON). Each user gets unique login/password via SSH.
# Example:
# PROXY_SERVERS_JSON=[{"id":"nl1","country":"NL","label":"Нидерланды · AMS","host":"72.56.86.167",...}]
# country — ISO 3166-1 alpha-2 (для флага и авто-названия); label — опционально, своя подпись вместо авто.
# Для dedicated IPv4 из Timeweb можно указать timewebServerId у площадки:
# [{"id":"nl1","country":"NL","host":"72.56.86.167","timewebServerId":"123456", ...}]
PROXY_SERVERS_JSON=[]
# Timeweb API (для авто-выдачи/ротации выделенного IPv4)
# TIMEWEB_API_BASE_URL=https://api.timeweb.cloud
# TIMEWEB_API_TOKEN=

# Временная ручная выдача подписки админом (до полной платежки):
# задайте длинный секрет и дергайте POST /api/admin/grant-subscription
# с заголовком x-admin-secret: <ADMIN_GRANT_SECRET>
ADMIN_GRANT_SECRET=

PAYMENT_WEBHOOK_SECRET=
# Глобальный лимит запросов на API (в минуту). 0/пусто — по умолчанию 240.
# RATE_LIMIT_RPM=240
# Режим Telegram-платежей: prod (боевой поток) или test (тестовые подсказки/кнопки)
# TG_PAYMENT_MODE=prod
# Сколько раз повторять createInvoiceLink при таймаутах провайдера (по умолчанию 4)
# TG_INVOICE_LINK_RETRIES=4
# URL оплаты для мини-приложения: плейсхолдеры {telegramId} {productCode} {grantDays} {username}
# Пример: https://pay.example.com/?tg={telegramId}&code={productCode}&days={grantDays}
# PAYMENT_CHECKOUT_URL_TEMPLATE=
# PAYMENT_DEFAULT_PRODUCT_CODE=vps_30
# Тестовые Telegram-платежи (ЮKassa через BotFather -> Payments)
# TG_PAYMENT_PROVIDER_TOKEN=
# TG_PAYMENT_CURRENCY=RUB
# Минимальная сумма одного счёта (в рублях для RUB). По умолчанию 60 — иначе ЮKassa/Telegram часто возвращают CURRENCY_TOTAL_AMOUNT_INVALID.
# TG_PAYMENT_MIN_INVOICE_AMOUNT=60
# TG_PAYMENT_TEST_PRICE_MINOR=9900
# TG_PAYMENT_TEST_DAYS=30
# TG_PAYMENT_TEST_PRODUCT_CODE=vps_30
# TG_PAYMENT_TEST_TITLE=VPS Premium — тестовый платёж
# TG_PAYMENT_TEST_DESCRIPTION=Тестовая оплата доступа к VPS Premium через Telegram Payments
# Цены (в копейках) по code, JSON-объект. Пример:
# TG_PAYMENT_PRICE_MAP_JSON={"vps_7":2500,"vps_30":10000,"vps_90":30000,"vps_180":60000,"proxy_7":1800,"proxy_30":7200}

# CORS_ORIGIN=https://...

# Тестовый режим: выдавать/продлевать подписку без проверки оплаты
# 1 = включено, 0/пусто = выключено
TEST_GRANT_ENABLED=0

# Баланс + почасовое списание за VPS (после первого пополнения; списание только при ACTIVE в XUI)
# BALANCE_BILLING_ENABLED=1
# Копеек за час (по умолчанию ~ цена vps_7 за неделю / 168)
# BALANCE_VPS_HOURLY_MINOR=15
# Прокси как надбавка к почасовому списанию (72 ₽/мес ≈ 10 коп/час)
# BALANCE_PROXY_HOURLY_MINOR=10
# Выделенный IPv4 как надбавка (180 ₽/мес ≈ 25 коп/час)
# BALANCE_DEDICATED_IP_HOURLY_MINOR=25