PORT=3000
NODE_ENV=production

BOT_TOKEN=
WEB_APP_URL=
PUBLIC_BASE_URL=
WEBHOOK_SECRET=

# Если в логах ETIMEDOUT на setWebhook — с хоста не достучаться до api.telegram.org (блокировка/фаервол).
# Мини‑приложение при этом может работать, если процесс не падает; см. устойчивый старт в src/index.js.
# TELEGRAM_SKIP_WEBHOOK_SETUP=1
# TELEGRAM_WEBHOOK_RETRIES=12
# TELEGRAM_WEBHOOK_RETRY_MS=5000
# TELEGRAM_WEBHOOK_RETRY_INTERVAL_MS=300000
# Node 20 fetch по умолчанию не читает HTTPS_PROXY; при необходимости поднимайте бота на VPS с доступом к Telegram API.

SESSION_JWT_SECRET=

# Subscription source (fixed to XUI)
PRIMARY_SUBSCRIPTION_SOURCE=xui

# Optional: 3X-UI base URL. Needed only if you link by token (sub id) instead of full URL.
# Example: https://panel.example.com:2096
XUI_BASE_URL=
# Panel URL (login + /panel/api/*). Often same as XUI_BASE_URL.
XUI_PANEL_BASE_URL=
# Точный Web Base Path из панели (например /8dFlsHsLZMTgKsrUhd/). С регистром как в 3X-UI.
XUI_WEB_BASE_PATH=
XUI_USERNAME=
XUI_PASSWORD=
# Inbound ID where bot should create clients
XUI_INBOUND_ID=
# Subscription path root (default: /sub)
XUI_SUB_PATH=/sub
# If 3X-UI uses self-signed TLS cert, set to 1.
XUI_INSECURE_TLS=0
# Имя узла в VPN-клиенте (remark в 3X-UI). Плейсхолдеры: {subscriptionTitle} {telegramId} {username}
# XUI_CLIENT_REMARK_TEMPLATE={subscriptionTitle} · {username}
# Суффикс, который часть клиентов показывает после имени (в формате remark-email).
# Поставьте флаг, например: 🇷🇺
# XUI_CLIENT_DISPLAY_SUFFIX=🌐

# Proxy servers list (JSON). Each user gets unique login/password via SSH.
# Example:
# PROXY_SERVERS_JSON=[{"id":"nl1","country":"NL","label":"Нидерланды · AMS","host":"72.56.86.167",...}]
# country — ISO 3166-1 alpha-2 (для флага и авто-названия); label — опционально, своя подпись вместо авто.
PROXY_SERVERS_JSON=[]

PAYMENT_WEBHOOK_SECRET=
# Режим Telegram-платежей: prod (боевой поток) или test (тестовые подсказки/кнопки)
# TG_PAYMENT_MODE=prod
# Сколько раз повторять createInvoiceLink при таймаутах провайдера (по умолчанию 4)
# TG_INVOICE_LINK_RETRIES=4
# URL оплаты для мини-приложения: плейсхолдеры {telegramId} {productCode} {grantDays} {username}
# Пример: https://pay.example.com/?tg={telegramId}&code={productCode}&days={grantDays}
# PAYMENT_CHECKOUT_URL_TEMPLATE=
# PAYMENT_DEFAULT_PRODUCT_CODE=vps_30
# Тестовые Telegram-платежи (ЮKassa через BotFather -> Payments)
# TG_PAYMENT_PROVIDER_TOKEN=
# TG_PAYMENT_CURRENCY=RUB
# TG_PAYMENT_TEST_PRICE_MINOR=9900
# TG_PAYMENT_TEST_DAYS=30
# TG_PAYMENT_TEST_PRODUCT_CODE=vps_30
# TG_PAYMENT_TEST_TITLE=VPS Premium — тестовый платёж
# TG_PAYMENT_TEST_DESCRIPTION=Тестовая оплата доступа к VPS Premium через Telegram Payments
# Цены (в копейках) по code, JSON-объект. Пример:
# TG_PAYMENT_PRICE_MAP_JSON={"vps_7":14900,"vps_30":39900,"vps_90":99000,"vps_180":179000,"proxy_7":24900,"proxy_30":79900}
# Webhook оплаты может передавать feeAmount, netAmount, serverId — колонки в NocoBase orders: см. docs/NOCOBASE.md

# CORS_ORIGIN=https://...

# Тестовый режим: выдавать/продлевать подписку без проверки оплаты
# 1 = включено, 0/пусто = выключено
TEST_GRANT_ENABLED=0

# --- NocoBase (операционная панель: клиенты, заказы, каталог, учёт прокси) ---
# Полная инструкция: docs/NOCOBASE.md
# NOCOBASE_BASE_URL=https://nocobase.example.com
# NOCOBASE_API_TOKEN=
# Либо вместо токена (менее безопасно для прода):
# NOCOBASE_ACCOUNT=
# NOCOBASE_PASSWORD=
# Переименование коллекций в UI (если отличаются):
# NOCOBASE_COLLECTION_CUSTOMERS=customers
# NOCOBASE_COLLECTION_ORDERS=orders
# NOCOBASE_COLLECTION_PRODUCTS=products
# NOCOBASE_COLLECTION_PROXY_INSTANCES=proxy_instances
# NOCOBASE_COLLECTION_SUBSCRIPTION_BRANDING=subscription_branding